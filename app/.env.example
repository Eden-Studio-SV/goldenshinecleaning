# Firebase — Web app config (Console → Project settings → Tus apps → SDK setup)
# Copia este archivo a `.env` y rellena los valores. `.env` NO se commitea.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional — App Check (reCAPTCHA v3) para anti-spam del formulario público (§7).
# Déjalo vacío si no usas App Check todavía.
VITE_RECAPTCHA_SITE_KEY=

# Administradores del panel (login con Google), separados por coma.
# DEBE mantenerse en sync con la lista en firestore.rules.
VITE_ADMIN_EMAILS=info@edenstudio.dev
