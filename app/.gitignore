# dependencias
node_modules
.pnp
.pnp.js

# build
dist
dist-ssr
*.local

# entorno
# .env / .env.local guardan la config local y NUNCA se commitean.
.env
.env.*
!.env.example
# .env.production sí se versiona a propósito: solo contiene la config web de
# Firebase (pública por diseño) para que Vercel construya sin variables manuales.
!.env.production

# firebase
.firebase
firebase-debug.log
firestore-debug.log
*-debug.log

# editor / OS
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript incremental build cache
*.tsbuildinfo
